# agent-bark-notify settings-guard 默认配置
# 保护 agent-bark-notify 相关字段，防被 cc-switch/CC 升级冲掉 settings.json
#
# 每行 3 段 TAB 分隔：jq路径 <TAB> 策略 <TAB> 期望值(JSON)
# 策略：missing=缺才补 / change=偏就纠 / both=缺或偏都纠
# $HOME 自动展开

# --- agent-bark-notify 核心字段（所有用户通用，建议保留）---

# plugin 启用状态（被冲掉会导致 hook 不触发、没通知）
.enabledPlugins	both	{"agent-bark-notify@agent-bark-notify":true}

# marketplace 源（被冲掉下次重装要重新 add）
.extraKnownMarketplaces	both	{"agent-bark-notify":{"source":{"source":"github","repo":"pamler1004/agent-bark-notify"}}}

# 通知图标（plugin 内置图标 raw URL，被冲掉回退 Bark 默认）
.env.BARK_ICON	both	"https://raw.githubusercontent.com/pamler1004/agent-bark-notify/main/assets/icon.png"

# --- 个人偏好字段（按需取消注释改成你自己的）---

# 通知声音（如 calypso；不填用 Bark app 默认）
# .env.BARK_SOUND	both	"calypso"

# 自定义 statusLine（防 cc-switch/升级覆盖；改成你自己的 statusLine）
# .statusLine	change	{"type":"command","command":"bash $HOME/.claude/statusline.sh"}
